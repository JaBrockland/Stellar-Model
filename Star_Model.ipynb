      "source": [
        "## Machine Readable Table"
      ],
      "metadata": {
        "id": "N6WTQPGDPgDc"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "#Setup to calculate non-fitted values\n",
        "stepcount=len(mass)\n",
        "\n",
        "X=0.7\n",
        "Z=0.02\n",
        "myu=4/(3+5*X-Z)\n",
        "\n",
        "density=[]\n",
        "opacity=[]\n",
        "eps=[]\n",
        "nabla=[]\n",
        "nabla_ad=[]\n",
        "radorconv=[]\n",
        "\n",
        "#Loops over the lists for fitted quantites to calculate non-fitted quantities\n",
        "for n in range(stepcount):\n",
        "  #Recalculates the density at a given mass step\n",
        "  Rho0=rho(P[n],T[n],myu)\n",
        "  density.append(Rho0)\n",
        "\n",
        "  #Recalculates the opacity\n",
        "  OpacityRho=logrhotologR(np.log10(Rho0),np.log10(T[n]))\n",
        "  opacity0=kappa(np.log10(T[n]),OpacityRho)[0]\n",
        "  opacity.append(opacity0)\n",
        "\n",
        "  #Recalculates the energy generation rate\n",
        "  eps0=engenrate(Rho0,T[n])\n",
        "  eps.append(eps0)\n",
        "\n",
        "  #Calculates the adiabatic and radiative temperature gradient\n",
        "  DelAd=0.4 #Convective gradient for an ideal gas\n",
        "  DelRad=(3/(16*np.pi*a*c*G))*((P[n]*opacity0)/T[n]**4)*(L[n]/mass[n])\n",
        "\n",
        "  nabla_ad.append(0.4)\n",
        "\n",
        "  nabla.append(DelRad)\n",
        "\n",
        "\n",
        "  #Decides if the star radiates or convects at this mass step, and adds that\n",
        "  #   information to a list\n",
        "  if DelRad>=DelAd:\n",
        "    Del=DelAd\n",
        "    radorconv.append('Convects')\n",
        "  elif DelAd>DelRad:\n",
        "    Del=DelRad\n",
        "    radorconv.append('Radiates')\n",
        "  else:\n",
        "    radorconv.append('Neither')"
      ],
      "metadata": {
