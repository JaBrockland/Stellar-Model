        "\n",
        "\n",
        "#Normalizes quantities for plotting\n",
        "massnorm=mass/M\n",
        "Pnorm= P/P[0]\n",
        "Tnorm= T/T[0]\n",
        "Rnorm= R/R[-1]\n",
        "Lnorm= L/L[-1]\n",
