    {
      "cell_type": "code",
      "source": [
        "#Derivative calculator, four equations of stellar structure to solve\n",
        "def derivs(m_input, params):\n",
        "  P,T,r,L=params\n",
        "\n",
        "  #Calculates mean molecular weight and density\n",
        "  mu=4/(3+5*X-Z)\n",
        "  Rho=rho(P,T,mu)\n",
        "\n",
        "  #Produces input values for opacity table, and establishes opacity at a step\n",
        "  logT=np.log10(T)\n",
        "  logrho=np.log10(Rho)\n",
        "  logR=logrhotologR(logrho,logT)\n",
        "  K=float(kappa(logT,logR)[0])\n",
        "\n",
        "\n",
        "  DelAd=0.4 #Convective gradient for an ideal gas\n",
        "  DelRad=(3/(16*np.pi*a*c*G))*((P*K)/T**4)*(L/m_input) #Eq 4.30 in Hansen Kawaler and Trimble 2004\n",
        "\n",
        "  eps=engenrate(Rho,T) #Evaluates the energy generation rate at a given step\n",
        "\n",
        "  #Decides if the star radiates or convects at this mass step\n",
        "  if DelRad>=DelAd:\n",
        "    Del=DelAd\n",
        "  elif DelAd>DelRad:\n",
        "    Del=DelRad\n",
        "  else:\n",
        "    Del=np.inf\n",
        "\n",
        "  #Calculates the derivative for the four physical quantities\n",
        "  dP=-G*m_input/(4*np.pi*r**4)\n",
        "  dT=Del*(-G*m_input*T)/(4*np.pi*(r**4)*P)\n",
        "  dr=1/(4*np.pi*r**2*Rho)\n",
        "  dL=eps\n",
        "\n",
        "  return(dP, dT, dr, dL,)"
      ],
