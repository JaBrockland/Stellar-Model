        "## Setup Functions For the Solver\n",
        "\n",
        "Initial surface and core values, as well as the derivative function to solve as an initial value problem.\n"
      ],
      "metadata": {
        "id": "yyDrcSZgmRZC"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "#Initial values at the core of the star, takes in P and T guesses, produces its\n",
        "#   own R, and L values for one mass step out\n",
        "def load1(m0,Pguess,Tguess):\n",
        "  mu=4/(3+5*X-Z)\n",
        "\n",
        "  #Values at the CORE\n",
        "  P0=Pguess\n",
        "  T0=Tguess\n",
        "  rho0= rho(P0,T0,mu)\n",
        "  eps0 = engenrate(rho0, T0)\n",
        "  k0=float(kappa(np.log10(T0),logrhotologR(np.log10(rho0),np.log10(T0)))[0])\n",
        "\n",
        "  #Values one step out\n",
        "  rc= (m0**(1/3))*(3/(4*np.pi*rho0))**(1/3)\n",
        "  Pc=P0-(3*G/(8*np.pi))*((4*np.pi*rho0/3)**(4/3))*(m0**(2/3))\n",
        "\n",
        "  #Radiative Tc\n",
        "  #Tc=((T0**4)-(1/(2*a*c))*((3/(4*np.pi))**(2/3))*k0*eps0*(rho0**(4/3))*m0**(2/3))**0.25 #THIS GUY IS FUCKED UP\n",
        "\n",
        "  #Convective Tc\n",
        "  Tc=np.exp(np.log(T0)-((np.pi/6)**(1/3))*G*((0.4*rho0**(4/3))/(P0))*(m0**(2/3)))\n",
        "\n",
        "  rhoc=rho(Pc,Tc,mu)\n",
        "  Lc=eps0*m0\n",
        "  epsc=engenrate(rhoc,Tc)\n",
        "\n",
        "\n",
        "  return(Pc, float(Tc), rc, float(Lc))\n",
        "\n",
        "\n",
        "#Equation to produce a rho that makes two guesses for P equal. Fsolve minimizer\n",
        "#   is run on it to produce an initial surface density.\n",
        "def findrho(rhog, T, mu, m_s, r ):\n",
        "#  print(rhog[0])\n",
        "\n",
        "  rho=rhog[0]\n",
        "\n",
        "  findrhoT=np.log10(T)\n",
        "  findrhoR=logrhotologR(np.log10(rho),findrhoT)\n",
        "\n",
        "  #Checks to make sure input values remain on the table, produces a warning if not\n",
        "  #Separate from other warning to indicate to the solver something is wrong with\n",
        "  #   inputs not intermediate values\n",
        "  if not(-8.0<findrhoR<1.0):\n",
        "    print('Input P and T produce a density out of opacity table bounds, model may break')\n",
        "    print(np.log10(rho),findrhoT)\n",
        "    print(findrhoR)\n",
        "    return np.inf\n",
        "  if not(3.75<findrhoT<8.7):\n",
        "    print('Input T  out of opacity table bounds, model may break')\n",
        "    return np.inf\n",
        "\n",
        "  ks=float(kappa(findrhoT, findrhoR)[0]) #Produces opacity\n",
        "  P1= (2/3)*(G*m_s/r**2)*(1/ks) #Pressure on the surface, where optical depth=2/3\n",
        "  P2= rho*Na*kB*T/mu+a/3*(T**4) #Pressure from ideal gas and radiation\n",
        "  return(1-P1/P2) #0 when P1=P2\n",
        "\n",
        "\n",
        "#Initial values at the surface of the star, takes in L and R guesses, produces its\n",
        "#   own P, and T values for the surface\n",
        "def load2(mf,Rguess,Lguess):\n",
        "  #print('beginning load2') #!\n",
        "  mu=4/(3+5*X-Z)\n",
        "\n",
        "  Ts=(Lguess/(4*np.pi*sigma*(Rguess**2)))**0.25\n",
        "\n",
        "  rhos=scipy.optimize.fsolve(findrho, x0=1e-8, args=(Ts, mu, mf, Rguess))\n",
        "\n",
        "  Ps=rhos*Na*kB*Ts/mu+(a*Ts**4)/3\n",
        "  rs=Rguess\n",
        "  Ls=Lguess\n",
        "\n",
        "  return(float(Ps[0]), Ts, rs, Ls)"
      ],
      "metadata": {
        "id": "ydxNn6H0n8BO"
      },
