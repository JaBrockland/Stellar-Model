        "## Constants and Functions To Produce Physical Values"
      ],
      "metadata": {
        "id": "FsbktAX-mN3h"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "#constants\n",
        "Na=6.022*10**23\n",
        "kB=1.38*10**(-16)\n",
        "sigma= 5.67*10**(-5)\n",
        "c=2.9979*10**10\n",
        "a=4*sigma/c\n",
        "G=6.67*10**(-8)"
      ],
      "metadata": {
        "id": "DpD96ByFnsDl"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#Density\n",
        "\n",
        "def rho(P,T,mu): #Density for a given pressure, temperature, composition\n",
        "  return (mu/(Na*kB*T))*(P-((a*T**4)/3))\n",
        "\n",
        "#Energy Generation\n",
        "\n",
        "##Establish composition for testing purposes\n",
        "X=0.7\n",
        "Y=0.28\n",
        "Z=1-X-Y\n",
        "\n",
        "##Psi Factors from Temperature, linear model from fig 18.7 in Kippenhahn Weigert Weiss 2020\n",
        "def psi(T7):\n",
        "  if T7<=1:\n",
        "    return 1\n",
        "  elif 3>=T7>=2:\n",
        "    return 1.7-0.1*T7\n",
        "  elif T7>1 and T7<2:\n",
        "    return (3/5+2*T7/5)\n",
        "  else:\n",
        "    return 1.4\n",
        "\n",
        "def psi(T7):\n",
        "  if T7<=1:\n",
        "    return 1\n",
        "  elif 3.5>=T7>=1:\n",
        "    return 0.85+0.15*T7\n",
        "\n",
        "  elif T7>3.5:\n",
        "    return 1.4\n",
        "\n",
        "def epspp(rho, T): #Energy generation rate from the PP chain\n",
        "  T9=T/(1e9)\n",
        "\n",
        "  T7=T/(1e7)\n",
        "\n",
        "  zeta=1\n",
        "\n",
        "  f11=np.exp(5.92*10**-3*1*((zeta*rho)/(T7**3))**0.5) #KWW Eq 18.56 and 18.57\n",
        "\n",
        "  g11=1+3.82*(T9)+1.51*(T9**2)+0.144*(T9**3)-0.0114*(T9**4) # KWW Eq 18.63\n",
        "\n",
        "  epspp1=(2.57*10**4) * psi(T7) * f11 * g11 * rho * (X**2) * (T9**(-2/3)) * (np.exp((-3.381) / (T9**(1/3)))) #KWW Eq 18.63\n",
        "\n",
        "  return(epspp1)\n",
        "\n",
        "def epscno(rho, T,): #Energy generation rate from the CNO cycle\n",
        "  T9=T/(1e9)\n",
        "  T7=T/(1e7)\n",
        "  g141=1-2.00*(T9)+3.41*(T9**2)-2.43*(T9**3) #KWW Eq 18.65\n",
        "  epscno1=(8.24*10**25)*g141*(0.74*Z)*X*rho*(T9**(-2/3))*np.exp((-15.231*T9**(-1/3))-(T9/0.8)**2) #KWW Eq 18.65\n",
        "  return(epscno1)\n",
        "\n",
        "def engenrate(rho, T): #Sum the energy from the PP chain and CNO cycle\n",
        "  epspp1= epspp(rho,T)\n",
        "  epscno1= epscno(rho, T)\n",
        "  eps=(epspp1+epscno1)\n",
        "  return(eps)\n",
        "\n"
      ],
      "metadata": {
        "id": "ab801ToGnw0A"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#Kappa Production and Interpolation\n",
        "\n",
        "data=pd.read_csv('Tables/opacity.txt',sep=' ',header=None) #Opacity table, must be fully cleaned (just numbers)\n",
        "table_text=data.to_numpy()\n",
        "\n",
        "#Axes values\n",
        "Ropacity=[-8.0, -7.5, -7.0, -6.5, -6.0, -5.5, -5.0, -4.5, -4.0, -3.5, -3.0, -2.5, -2.0, -1.5, -1.0, -0.5, 0.0, 0.5, 1.0]\n",
        "Temp=[3.75,3.80,3.85,3.90,3.95,4.00,4.05,4.10,4.15,4.20,4.25,4.30,4.35,4.40,4.45,4.50,4.55,4.60,4.65,4.70,4.75,4.80,4.85,4.90,4.95,5.00,5.05,5.10,5.15,5.20,5.25,5.30,5.35,5.40,5.45,5.50,5.55,5.60,5.65,5.70,5.75,5.80,5.85,5.90,5.95,6.00,6.10,6.20,6.30,6.40,6.50,6.60,6.70,6.80,6.90,7.00,7.10,7.20,7.30,7.40,7.50,7.60,7.70,7.80,7.90,8.00,8.10,8.30,8.50,8.70]\n",
        "\n",
        "\n",
        "def logrhotologR(logrho,logT): #Produces R to be read for the table\n",
        "  rho=10**logrho\n",
        "  T=10**logT\n",
        "  T6=T*10**(-6)\n",
        "  R=rho/(T6**3)\n",
        "  return np.log10(R)\n",
        "\n",
        "#Produces an opacity for a given logT and log R, checks to make sure they are in bounds\n",
        "# #produces 10^20 for values outside the table, provides a warning\n",
        "def kappa(logt,logr):\n",
        "  if not(-8.0<logr<1.0):\n",
        "    print('R value out of opacity table bounds with '+str(logr))\n",
        "    return [10**20]\n",
        "  if not(3.75<logt<7.5):\n",
        "    print('T out of opacity table bounds with '+str(logt))\n",
        "    return [10**20]\n",
        "  else:\n",
        "    #Defines a function to interpolate the table\n",
        "    interpolatekappa=scipy.interpolate.RegularGridInterpolator([Temp,Ropacity],table_text,method=\"linear\")\n",
        "    #Interpolates the table for the provided values\n",
        "    logk=interpolatekappa([logt,logr])\n",
        "    print()\n",
        "\n",
        "    return 10**logk"
      ],
