    {
      "cell_type": "code",
      "source": [
        "#Functions used in the solver\n",
        "\n",
        "\n",
        "#Integrator moving from the core outward\n",
        "#Takes in a pressure and a temperature, produces a stellar model to a final position\n",
        "def integrate_out(P_guess,T_guess):\n",
        "\n",
        "  #Generates starting conditions at the stellar core\n",
        "  inparamsvals=load1(mstart,P_guess,T_guess)\n",
        "\n",
        "  #Numerically integrates the four equations of stellar structure from core to\n",
        "  #   a meeting point\n",
        "  soln_outward=scipy.integrate.solve_ivp(derivs, (mstart, mstop), inparamsvals, t_eval=None, method='Radau')\n",
        "\n",
        "\n",
        "  #Produces a bunch pbject with self.t as mass steps and self.y as solutions\n",
        "  return soln_outward\n",
        "\n",
        "\n",
        "#Integrator moving from the surface inward\n",
        "#Takes in a radius and a luminosity, produces a stellar model to a final position\n",
        "def integrate_in(r_guess,L_guess):\n",
        "\n",
        "  #Generates starting conditions at the stellar surface\n",
        "  inparamsvals=load2(M,r_guess,L_guess)\n",
        "\n",
        "  #Numerically integrates the four equations of stellar structure from surface\n",
        "  #   to a meeting point\n",
        "  soln_inward=scipy.integrate.solve_ivp(derivs, (M, mstop), inparamsvals, t_eval=None, method='Radau')\n",
        "\n",
        "  #Produces a bunch pbject with self.t as mass steps and self.y as solutions\n",
        "  return soln_inward\n",
        "\n",
        "\n",
        "#Function comparing the endpoints of integrate_in and integrate_out for a given\n",
        "#   set of starting conditions\n",
        "def score(params):\n",
        "  Pc,Tc,rf,Lf=params\n",
        "\n",
        "  #Establishes composition to check if initial values produce functioning opacities\n",
        "  X=0.7\n",
        "  Y=0.28\n",
        "  Z=1-X-Y\n",
        "  mutest=4/(3+5*X-Z)\n",
        "\n",
        "  #Pre-calculates values used to solve for opacity\n",
        "  Rhotest=rho(Pc,Tc,mutest)\n",
        "  logTtest=np.log10(Tc)\n",
        "  logRhotest=np.log10(Rhotest)\n",
        "\n",
        "  logRc=logrhotologR(logRhotest,logTtest)\n",
        "\n",
        "  #Checks if the opacity solving values are valid. If not, prints a warning and\n",
        "  #   returns a maximized score value\n",
        "  if logRc > 1 or logRc<-8 or logTtest > 8.7 or logTtest < 3.75 :\n",
        "    print('Initial values outside opacity table')\n",
        "    P1=float(10**50)\n",
        "    P2=float(1)\n",
        "    T1=float(10**50)\n",
        "    T2=float(1)\n",
        "    r1=float(10**50)\n",
        "    r2=float(1)\n",
        "    L1=float(10**50)\n",
        "    L2=float(1)\n",
        "    Pcore=1\n",
        "    Tcore=1\n",
        "    rcore=1\n",
        "    Lcore=1\n",
        "\n",
        "  #Checks if the input pressures, temperatures, densities and luminosities are\n",
        "  #   positive and not nan. If not, prints a warning and returns a maximized\n",
        "  #   score value.\n",
        "  elif Pc<=0 or Tc<=0 or Rhotest<=0 or Lf<=0 or np.isnan(Pc) or np.isnan(Tc)or np.isnan(logRc):\n",
        "    print('Negative or Nan values produced')\n",
        "    P1=float(10**50)\n",
        "    P2=float(1)\n",
        "    T1=float(10**50)\n",
        "    T2=float(1)\n",
        "    r1=float(10**50)\n",
        "    r2=float(1)\n",
        "    L1=float(10**50)\n",
        "    L2=float(1)\n",
        "    Pcore=1\n",
        "    Tcore=1\n",
        "    rcore=1\n",
        "    Lcore=1\n",
        "\n",
        "  #Procedes with the integration\n",
        "  else:\n",
        "    outwardsln=integrate_out(Pc,Tc)\n",
        "    inwardsln=integrate_in(rf,Lf)\n",
        "\n",
        "    #Takes the endpoint of the outgoing solution\n",
        "    P1=outwardsln.y[0, -1]\n",
        "    T1=outwardsln.y[1, -1]\n",
        "    r1=outwardsln.y[2, -1]\n",
        "    L1=outwardsln.y[3, -1]\n",
        "\n",
        "    #Takes the endpoint of the ingoing solution\n",
        "    P2=inwardsln.y[0, -1]\n",
        "    T2=inwardsln.y[1, -1]\n",
        "    r2=inwardsln.y[2, -1]\n",
        "    L2=inwardsln.y[3, -1]\n",
        "\n",
        "    #Takes the largest value for each quantity as a normalization factor\n",
        "    Pcore=outwardsln.y[0,0]\n",
        "    Tcore=outwardsln.y[1,0]\n",
        "    rsurface=outwardsln.y[2,0]\n",
        "    Lsurface=outwardsln.y[3,0]\n",
        "\n",
        "\n",
        "  #Calculates the fractional error between produced values at the meeting point\n",
        "  P_diff=np.abs((P1-P2)/(Pcore))\n",
        "  T_diff=np.abs((T1-T2)/(Tcore))\n",
        "  r_diff=np.abs((r1-r2)/(rsurface))\n",
        "  L_diff=np.abs((L1-L2)/(Lsurface))\n",
        "\n",
        "  #Quadrature sum of errors, used to diagnose issues with the code\n",
        "  score=np.sqrt(P_diff**2+T_diff**2+r_diff**2+L_diff**2)\n",
        "\n",
        "  #Prints the fractional errors and total score, so you can watch the code\n",
