        "Lin=shootin.y[3]\n",
        "Lin=Lin[::-1]\n",
        "\n",
        "\n",
        "mass=np.concatenate((massout, massin), axis=None)\n",
        "P=np.concatenate((Pout, Pin), axis=None)\n",
        "T=np.concatenate((Tout, Tin), axis=None)\n",
        "R=np.concatenate((Rout, Rin), axis=None)\n",
