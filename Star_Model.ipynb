        "#Initial Condition Producer\n",
        "#Uses homology relations and the radiation+ideal gas equation of state to produce\n",
        "# initial guess values for the solver.\n",
        "\n",
        "def Guesser(TestM_sun): #Takes in a mass in solar masses\n",
        "\n",
        "  #Chooses a set of exponents\n",
        "  if TestM_sun>1.3:\n",
        "    aR=0.78\n",
        "    arho=-1.33\n",
        "    aL=3.5\n",
        "    aT=0.22\n",
        "  elif TestM_sun<=1.3:\n",
        "    aR=0.2\n",
        "    arho=0.4\n",
        "    aL=3.9\n",
        "    aT=0.8\n",
        "  else:\n",
        "    aR=50\n",
        "    arho=50\n",
        "    aL=50\n",
        "    aT=50\n",
        "\n",
        "  #Calculates estimates based off the homology relations for solar values in ergs\n",
        "  Rp=6.96e10*(TestM_sun**aR)\n",
        "  rhop=150*(TestM_sun**arho)\n",
        "  Lp=3.828*10**33*(TestM_sun**aL)\n",
        "  Tp=1.5e7*(TestM_sun**aT)\n",
        "\n",
        "  Pp=(Na*kB*Tp*rhop/mu)+((a/3)*Tp**4)\n",
        "\n",
        "  #Returns the estimates\n",
        "  return[Pp,Tp,Rp,Lp]"
      ],
      "metadata": {
        "id": "4kgW3rUM5VO4"
